# Database
DB_HOST=
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_CONNECTION_LIMIT=5
DB_MAX_IDLE=5
DB_IDLE_TIMEOUT=600000

# Auth / background jobs (reduce DB connections on shared hosting)
AUTH_CACHE_TTL_MS=300000
PROJECT_MAPPING_CACHE_TTL_MS=120000
PROJECT_VALIDITY_CACHE_TTL_MS=120000
AISENSY_TOKEN_CACHE_TTL_MS=600000
PROJECT_DATA_CACHE_TTL_MS=300000
DEVELOPER_AUTH_CACHE_TTL_MS=300000
BILLING_CRON_ENABLED=true
BILLING_CRON_SCHEDULE=*/15 * * * *
WEBHOOK_SUBSCRIPTION_CRON=*/30 * * * *
WEBHOOK_QUEUE_INTERVAL_MS=3000
GENERATE_DB_SUMMARY=false

# AiSensy
AISENSY_PARTNER_ID=
AISENSY_API_KEY=

# App URLs
BASE_DOMAIN=https://api.example.com
APP_DOMAIN=https://app.example.com

# Google OAuth
GOOGLE_CLIENT_ID=

# Cloudflare Turnstile
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# SMTP
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Payment gateway (cashfree | razorpay | zwitch)
ACTIVE_GATEWAY=cashfree
CASHFREE_ENV=production
CASHFREE_APP_ID_PROD=
CASHFREE_SECRET_KEY_PROD=
CASHFREE_APP_ID_TEST=
CASHFREE_SECRET_KEY_TEST=

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

ZWITCH_PAYMENT_ACCESS_KEY=
ZWITCH_PAYMENT_AUTH_TOKEN=
ZWITCH_WEBHOOK_ACCESS_KEY=
ZWITCH_WEBHOOK_AUTH_TOKEN=

# Backblaze B2 (S3-compatible object storage for chat media)
# B2_ACCESS_KEY = keyID from Backblaze (e.g. 81a52e31f317)
# B2_SECRET_KEY = applicationKey secret (shown once when the key is created)
B2_ENDPOINT=https://s3.eu-central-003.backblazeb2.com
B2_REGION=eu-central-003
B2_BUCKET=
B2_ACCESS_KEY=
B2_SECRET_KEY=
# Signed download URL lifetime in seconds for private bucket (max 604800 = 7 days)
B2_DOWNLOAD_AUTH_TTL_SECONDS=86400
# Optional: override public file URL base (CDN or B2 friendly URL)
# B2_PUBLIC_URL=https://your-cdn.example.com
